# Copy to `.env` in the repo root (same folder as README). Never commit `.env`.
# FastAPI loads this on startup via python-dotenv.

# Vapi Web SDK (client-side public key — safe for browser, but keep out of git)
VAPI_PUBLIC_KEY=
VAPI_ASSISTANT_ID=

# Optional: same keys you may already use elsewhere
# GEMINI_API_KEY=
# QDRANT_URL=
# QDRANT_API_KEY=
