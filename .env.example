# Copy to `.env` in the repo root (same folder as README) or in `backend/`. Never commit `.env`.
# FastAPI loads this on startup via python-dotenv.

# Vapi Web SDK (client-side public key — safe for browser, but keep out of git)
VAPI_PUBLIC_KEY=
VAPI_ASSISTANT_ID=

# Extraction uses Gemini — required:
GEMINI_API_KEY=
# GOOGLE_API_KEY=   # alternative env name for the same key

# Qdrant — local Docker: docker compose up -d  then:
QDRANT_URL=http://127.0.0.1:6333
# QDRANT_API_KEY=   # only for Qdrant Cloud

# --- Notifications (Twilio) ---
# For real sends (SMS / WhatsApp): do **not** set SAATHI_NOTIFICATIONS_DEMO, and do not set
# SAATHI_DEMO_PHONE. Leave both absent so the app uses Twilio below. (If either demo var is
# set incorrectly, you get log-only + wa.me drafts instead of API sends.)
#
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_SMS_FROM=+1xxxxxxxxxx
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# SAATHI_ANM_WHATSAPP_TO=whatsapp:+9198xxxxxxxx
#   If no patients have per-ANM tags yet, daily register can fall back to this one number.
#   Sandbox: recipient must join your Twilio WhatsApp sandbox first.
# Per-ANM: set ANM WhatsApp in the app when saving visits (`registered_by_anm_whatsapp`).
#
# Optional — no Twilio: log-only visit-day “SMS” and wa.me daily-register drafts (not API sends)
# SAATHI_DEMO_PHONE=+9198xxxxxxxx
# If you have Twilio in .env but still need log/wa.me only, set: SAATHI_NOTIFICATIONS_DEMO=1

# --- Security (recommended for production) ---
# API key for authenticating requests to data endpoints. When unset, auth is bypassed (dev mode).
# SAATHI_API_KEY=

# Comma-separated list of allowed CORS origins. When unset, defaults to "*" (all origins, no credentials).
# Example: CORS_ORIGINS=https://my-app.onrender.com,http://localhost:3000
# CORS_ORIGINS=
