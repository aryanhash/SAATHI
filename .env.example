# Copy to `.env` in the repo root (same folder as README) or in `backend/`. Never commit `.env`.
# FastAPI loads this on startup via python-dotenv.

# Vapi Web SDK (client-side public key — safe for browser, but keep out of git)
VAPI_PUBLIC_KEY=
VAPI_ASSISTANT_ID=

# Extraction defaults to Gemini — required unless you use local Ollama:
GEMINI_API_KEY=
# GOOGLE_API_KEY=   # alternative env name for the same key
# SAATHI_LLM=ollama   # only if you intentionally run without Google AI (Ollama on localhost)

# Qdrant — local Docker: docker compose up -d  then:
QDRANT_URL=http://127.0.0.1:6333
# QDRANT_API_KEY=   # only for Qdrant Cloud

# --- Notifications: Twilio (production) OR demo (your number only) ---
# Real SMS/WhatsApp need a Twilio (or other) account — you send from a Twilio number, not "from" your own SIM.
#
# Option A — Demo without Twilio: set your mobile in E.164. Visit-day SMS is logged only; daily register
# returns a wa.me link you open on your phone (draft message, you tap Send). Optional force:
# SAATHI_NOTIFICATIONS_DEMO=0
# SAATHI_DEMO_PHONE=+9198xxxxxxxx
#
# Option B — Twilio (visit-day SMS; WhatsApp to ANM)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_SMS_FROM=+1xxxxxxxxxx
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# SAATHI_ANM_WHATSAPP_TO=whatsapp:+9198xxxxxxxx   # legacy single-recipient register
#
# Per-ANM daily register:
# - The UI now tags each saved patient with `registered_by_anm_whatsapp` (from the ANM WhatsApp field).
# - Use POST /api/notifications/daily-register/whatsapp/all to send one report per ANM.

# --- Security (recommended for production) ---
# API key for authenticating requests to data endpoints. When unset, auth is bypassed (dev mode).
# SAATHI_API_KEY=

# Comma-separated list of allowed CORS origins. When unset, defaults to "*" (all origins, no credentials).
# Example: CORS_ORIGINS=https://my-app.onrender.com,http://localhost:3000
# CORS_ORIGINS=
